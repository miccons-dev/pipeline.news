# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/pipeline_invites

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxx
FROM_EMAIL=Pipeline.news <crew@pipeline.news>

# Brevo — used by accept-invite to subscribe the invited user
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_LIST_ID=3

# Beehiiv — used only by scripts/fetch-posts.js (newsletter content)
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Frontend URL (used to build invite links)
SITE_URL=https://www.pipeline.news
